# ──────────────────────────────────────────────────────────────────
# Shippeasy — Docker Compose environment variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# This file is safe to commit. .env is gitignored.
# ──────────────────────────────────────────────────────────────────

# ── General ───────────────────────────────────────────────────────
NODE_ENV=production

# ── Ports (host-side) ─────────────────────────────────────────────
FRONTEND_PORT=80
BACKEND_PORT=3000

# ── MongoDB ───────────────────────────────────────────────────────
MONGO_DB_NAME=shipeasy

# ── Backend URL (used by nginx proxy at runtime) ──────────────────
# Must match the internal Docker Compose service name and port.
BACKEND_URL=http://backend:3000

# ── Angular build-time API URLs ───────────────────────────────────
# Defaults to /api and /api/ so nginx proxies requests to the backend.
# Override with absolute URLs only for cross-domain / split-host setups.
API_URL=/api
API_URL_MASTER=/api/

# Set SOCKET_URL to override the Socket.io URL.
# Leave empty to default to same origin (recommended with nginx proxy).
SOCKET_URL=

# ── CI/CD — Azure Container Registry (ACR) ───────────────────────
# BACKEND_IMAGE / FRONTEND_IMAGE / *_TAG are written by deploy.sh
# on each deployment. Leave defaults here; the pipeline overrides them.
#
# ACR_NAME is your registry name (without .azurecr.io suffix).
# Example: if your ACR URL is shippeasy.azurecr.io, set ACR_NAME=shippeasy
ACR_NAME=your-acr-name

BACKEND_IMAGE=$(ACR_NAME).azurecr.io/shipeasy-api
FRONTEND_IMAGE=$(ACR_NAME).azurecr.io/shipeasy-frontend
BACKEND_TAG=latest
FRONTEND_TAG=latest

# ── ACR service principal (EC2 server only — NOT committed) ───────
# Create a service principal with AcrPull role on the ACR resource.
# Store these in the server .env only — never commit.
# ACR_USERNAME=<service-principal-client-id>
# ACR_PASSWORD=<service-principal-client-secret>

