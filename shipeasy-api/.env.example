# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
MONGO_CONNECTION=mongodb://localhost:27017/shipeasy
MONGO_DB_NAME=shipeasy

# =============================================================================
# JWT AUTHENTICATION
# =============================================================================
SECRET_KEY_JWT=your-jwt-secret-key-here
TOKEN_EXPIRE_TIME=7d

# =============================================================================
# GOOGLE OAUTH
# =============================================================================
OAUTHCLIENT=your-google-oauth-client-id

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
PORT=3000
ENVIRONMENT=development
NODE_ENV=development

# =============================================================================
# CORS SETTINGS
# =============================================================================
# Comma-separated list of allowed origins for CORS
CORS_ORIGINS=http://localhost:3000,https://app.shipeasy.com,https://staging.shipeasy.com

# =============================================================================
# FILE UPLOAD SETTINGS
# =============================================================================
# Directory for temporary file uploads (relative to app root or absolute path)
UPLOAD_DIRECTORY=./uploads
MAX_FILE_SIZE=52428800
# Max number of files per upload
MAX_FILES_PER_UPLOAD=10

# =============================================================================
# FRONTEND URL
# =============================================================================
FRONTEND_URL=http://localhost:3000

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================
EMAIL_SMTP=your-email@domain.com
PASS_SMTP=your-email-password
SERVER_SMTP=smtp.gmail.com
EMAIL_KEY=your-sendinblue-api-key

# =============================================================================
# AZURE STORAGE
# =============================================================================
AZURE_STORAGE_CONNECTION_STRING=your-azure-storage-connection-string
AZURE_CONTAINER_NAME=your-container-name

# =============================================================================
# REDIS CONFIGURATION (for queues)
# =============================================================================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# =============================================================================
# APM & MONITORING
# =============================================================================
APM_SERVER=http://localhost:8200
ELASTIC_APM_SERVICE_NAME=shipeasy-api
ELASTIC_APM_ENVIRONMENT=development

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=info
LOG_FILE_PATH=./logs

# CloudWatch centralized logging (optional — logs also go to files + console)
# Set CLOUDWATCH_LOG_GROUP to enable; leave empty to disable.
CLOUDWATCH_LOG_GROUP=
CLOUDWATCH_RETENTION_DAYS=30
CLOUDWATCH_LOG_LEVEL=info

# =============================================================================
# EXTERNAL API INTEGRATIONS
# =============================================================================

# Freightos API
FREIGHTOS_URL=https://api.freightos.com
FREIGHTOS_API_KEY=your-freightos-api-key

# OceanIO API
OCEANO_URL=https://api.oceano.com
OCEANO_API_KEY=your-oceano-api-key

# ULIP Server
ULIP_SERVER_URL=https://ulip-server-url.com

# WhatsApp Business API
WHATSAPP_PHONE_NUMBER_ID=your-whatsapp-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_VERIFY_TOKEN=your-whatsapp-verify-token

# OceanIO Webhook
OCEANIO_WEBHOOK_SECRET=your-oceanio-webhook-secret

# =============================================================================
# JASPER REPORTS
# =============================================================================
JASPER_URL=http://your-jasper-server:8080
JASPER_Auth=base64-encoded-credentials
JASPER_PATH=reports/path

# =============================================================================
# API KEY (defense-in-depth — validated when set, skipped when empty)
# =============================================================================
X_API_KEY=

# =============================================================================
# ENCRYPTION (for request/response encryption)
# =============================================================================
ENCRYPTION=false
# Must be exactly 32 characters — CHANGE THIS IN PRODUCTION
ENCRYPTION_KEY=

# =============================================================================
# SWAGGER
# =============================================================================
# In production, Swagger UI is disabled by default. Set to true to enable.
ENABLE_SWAGGER=false

# =============================================================================
# CIRCUIT BREAKER SETTINGS
# =============================================================================
CIRCUIT_BREAKER_ENABLED=true
CIRCUIT_BREAKER_TIMEOUT=30000
CIRCUIT_BREAKER_ERROR_THRESHOLD=50
CIRCUIT_BREAKER_RESET_TIMEOUT=30000